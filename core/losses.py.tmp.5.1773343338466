# core/losses.py
# Loss functions and evaluation metrics for bubble segmentation
# These metrics measure how well predictions match ground truth masks
from __future__ import annotations

from typing import Tuple

import torch
import torch.nn.functional as F

# Small constant added to avoid division-by-zero errors
# (e.g., when both pred and ground truth are empty)
_EPS = 1e-6

# Try to import scipy for advanced boundary-quality metrics.
# Scipy enables Hausdorff distance (HD95) and normalized surface distance (NSD),
# which measure boundary errors in pixels rather than just overlap.
# These are optional but strongly recommended for accurate surface distance evaluation.
try:
    import numpy as np
    from scipy.ndimage import binary_erosion, distance_transform_edt

    _HAS_SCIPY = True
except Exception:  # pragma: no cover
    _HAS_SCIPY = False
    np = None  # type: ignore[assignment]
    binary_erosion = None  # type: ignore[assignment]
    distance_transform_edt = None  # type: ignore[assignment]


def _ensure_nchw_1(yt: torch.Tensor, yp: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
    """
    Normalize input tensors to a standard shape: (B, 1, H, W).

    WHY THIS MATTERS: Different models output shapes in different formats
    (some use (B, H, W), others (B, C, H, W), others even (B, H, W, C)).
    This function converts everything to the NCHW convention (Batch, Channel, Height, Width)
    where there's exactly 1 channel (binary mask for bubble detection).

    It also handles edge cases like resizing y_pred to match y_true's spatial dimensions,
    and clamps values to [0, 1] for probability-like outputs.
    """
    # Convert y_true to (B, 1, H, W)
    # If input is 3D (H, W, or B, H, W), add a batch or channel dimension
    if yt.ndim == 3:
        yt = yt.unsqueeze(1)
    if yt.ndim != 4:
        raise ValueError(f"y_true must be 3D/4D, got {yt.ndim}D")
    if yt.shape[1] != 1:
        # If multi-channel, extract the foreground channel (class 1 = bubbles)
        # or just take the first channel if only one exists
        if yt.shape[1] > 1:
            yt = yt[:, 1:2]  # Extract channel 1 (bubbles) from multi-channel
        else:
            yt = yt[:, :1]
    # Clamp to [0, 1] range and convert to float
    yt = yt.float().clamp(0.0, 1.0)

    # Convert y_pred (prediction) to (B, 1, H, W)
    # Same logic as y_true, but for model predictions
    if yp.ndim == 3:
        yp = yp.unsqueeze(1)
    if yp.ndim != 4:
        raise ValueError(f"y_pred must be 3D/4D, got {yp.ndim}D")

    # NHWC detection: if dimension 1 looks wrong but dimension 3 looks right, permute
    # This catches models that output channels in the last position (NumPy convention)
    # instead of position 1 (PyTorch convention)
    if yp.shape[1] not in (1, yt.shape[1]) and yp.shape[-1] in (1, yt.shape[1]):
        yp = yp.permute(0, 3, 1, 2).contiguous()  # NHWC -> NCHW

    # If multi-class output, extract the bubble class (channel 1)
    if yp.shape[1] > 1:
        cls_idx = 1 if yp.shape[1] > 1 else 0
        yp = yp[:, cls_idx:cls_idx + 1]

    # Handle edge case: predictions with no channels (malformed tensor)
    if yp.shape[1] == 0:
        yp = torch.zeros(
            (yt.shape[0], 1, max(1, yp.shape[-2]), max(1, yp.shape[-1])),
            dtype=torch.float32,
            device=yt.device,
        )

    # Ensure spatial dimensions match: resize predictions to ground truth's H, W
    # This handles cases where the model outputs a different resolution than the input
    if yp.shape[-2:] != yt.shape[-2:]:
        if yp.numel() == 0 or yp.shape[-2] == 0 or yp.shape[-1] == 0:
            # Empty prediction tensor: fill with zeros at correct size
            yp = torch.zeros(
                (yt.shape[0], 1, yt.shape[-2], yt.shape[-1]),
                dtype=torch.float32,
                device=yt.device,
            )
        else:
            # Resize using bilinear interpolation (smooth, differentiable)
            yp = F.interpolate(
                yp.float(), size=yt.shape[-2:], mode="bilinear", align_corners=False
            )

    # Clamp predictions to a safe probability range [eps, 1-eps]
    # (not [0, 1] to avoid log(0) in downstream loss computations)
    yp = yp.float().clamp(_EPS, 1.0 - _EPS)
    return yt, yp


# ================ Basic metrics ================
# These measure segmentation quality using different perspectives on overlap and correctness

def dice_coef(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    Dice Coefficient (also called Sørensen–Dice Index).

    WHY IT MATTERS:
    Dice measures overlap between predicted and ground truth masks.
    It's especially useful for imbalanced data where one class is rare (like bubbles in an image).
    Unlike accuracy, Dice doesn't penalize predicting nothing when the object is truly absent.

    FORMULA: Dice = 2 * |intersection| / (|pred| + |ground_truth|)
    - Ranges from 0 (no overlap) to 1 (perfect match)
    - The "2.0 *" upweights intersection to balance the denominator

    PIXEL-BY-PIXEL INTUITION:
    If pred = [0.9, 0.8, 0.2] and truth = [1, 1, 0], then:
      intersection = 0.9 + 0.8 = 1.7
      sum(truth) = 2, sum(pred) = 1.9
      dice = 2 * 1.7 / (2 + 1.9) ≈ 0.9
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Intersection: element-wise multiply (only where both pred and truth are high)
    inter = torch.sum(yt * yp, dim=(1, 2, 3))

    # Denominator: sum of all predicted mass plus all ground truth mass
    den = torch.sum(yt, dim=(1, 2, 3)) + torch.sum(yp, dim=(1, 2, 3))

    # Compute Dice per batch, add eps to avoid division by zero
    dice = (2.0 * inter + eps) / (den + eps)

    return dice.mean()  # Average across batch


def dice_loss(y_true: torch.Tensor, y_pred: torch.Tensor) -> torch.Tensor:
    """
    Dice Loss: 1 - Dice Coefficient.
    Used during training to encourage high Dice scores.
    (A loss function should be minimized; hence we subtract from 1.)
    """
    return 1.0 - dice_coef(y_true, y_pred)


def IoU(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    Intersection over Union (IoU), also called Jaccard Index.

    WHY IT MATTERS:
    IoU measures how well pred and truth overlap relative to their combined area.
    Stricter than Dice (penalizes false positives and false negatives equally).

    FORMULA: IoU = |intersection| / |union|
    - union = |pred| + |ground_truth| - |intersection|
    - Ranges from 0 (no overlap) to 1 (perfect match)

    COMPARISON WITH DICE:
    Dice and IoU are related: IoU = Dice / (2 - Dice)
    - Dice is more lenient; IoU is stricter
    - Use Dice for imbalanced data, IoU for balanced evaluation
    - Both value intersection, but IoU penalizes non-overlapping areas more harshly
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Intersection: element-wise product (high only where both are high)
    inter = torch.sum(yt * yp, dim=(1, 2, 3))

    # Union: all pixels that are "on" in either pred or truth, minus double-counted overlap
    # (sum(A + B) - intersection to avoid counting intersection twice)
    union = torch.sum(yt + yp, dim=(1, 2, 3)) - inter

    # IoU = intersection / union
    iou = (inter + eps) / (union + eps)

    return iou.mean()  # Average across batch


def accuracy(y_true: torch.Tensor, y_pred: torch.Tensor) -> torch.Tensor:
    """
    Pixel-level Accuracy: fraction of pixels correctly classified.

    WHY CAUTION IS NEEDED:
    Accuracy looks good when one class dominates. If 95% of pixels are background,
    a model that predicts "all background" achieves 95% accuracy—but detects NO bubbles!
    This is why Dice, IoU, or Tversky are better for imbalanced problems.

    COMPUTATION:
    1. Threshold predictions at 0.5 (convert probabilities to binary)
    2. Compare to binary ground truth
    3. Count matches across all pixels and average across batch
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Threshold: predictions >= 0.5 are "bubble", < 0.5 are "background"
    yb = (yp >= 0.5).float()

    # Count pixels where prediction matches ground truth (both thresholded at 0.5)
    correct = torch.sum((yb == (yt >= 0.5)).float(), dim=(1, 2, 3))

    # Total pixels per image
    total = yt.shape[2] * yt.shape[3]

    return (correct / total).mean()  # Accuracy per image, averaged across batch


def sensitivity(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    Sensitivity (also called Recall or True Positive Rate).

    WHAT IT MEASURES: "Of all actual bubbles, how many did we find?"
    Sensitivity = TP / (TP + FN)
    - TP (True Positive): predicted bubble, actually is a bubble
    - FN (False Negative): predicted background, actually is a bubble
    - High sensitivity = catch almost all bubbles (low false negative rate)
    - Low sensitivity = miss many bubbles

    WHY IT MATTERS FOR BUBBLES:
    Missing bubbles (FN) is often worse than false alarms (FP), so high sensitivity is critical.
    For example: in quality control, missing defects is costlier than inspecting false alarms.
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Threshold predictions at 0.5
    yb = (yp >= 0.5).float()

    # True Positives: correctly predicted as bubble (1 * 1)
    tp = torch.sum(yb * yt, dim=(1, 2, 3))

    # False Negatives: predicted background but is actually bubble ((1 - 1) * 1 = 0 but we want: predicted 0, truth 1)
    fn = torch.sum((1 - yb) * yt, dim=(1, 2, 3))

    # Sensitivity = TP / (TP + FN)
    return ((tp + eps) / (tp + fn + eps)).mean()  # Average across batch


def specificity(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    Specificity (also called True Negative Rate or 1 - False Positive Rate).

    WHAT IT MEASURES: "Of all actual background, how much did we correctly reject?"
    Specificity = TN / (TN + FP)
    - TN (True Negative): predicted background, actually is background
    - FP (False Positive): predicted bubble, actually is background
    - High specificity = few false alarms (low false positive rate)
    - Low specificity = many false positives

    WHY IT MATTERS FOR BUBBLES:
    False positives (incorrectly flagging background as bubbles) waste inspection time.
    Balance between sensitivity (catch all bubbles) and specificity (avoid false alarms).
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Threshold predictions at 0.5
    yb = (yp >= 0.5).float()

    # True Negatives: correctly predicted as background ((1 - 0) * (1 - 0) = 1 when both are background)
    tn = torch.sum((1 - yb) * (1 - yt), dim=(1, 2, 3))

    # False Positives: predicted bubble but is actually background (1 * (1 - 1) when pred=1, truth=0)
    fp = torch.sum(yb * (1 - yt), dim=(1, 2, 3))

    # Specificity = TN / (TN + FP)
    return ((tn + eps) / (tn + fp + eps)).mean()  # Average across batch


def f1_score(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    F1 Score: Harmonic mean of Precision and Recall.

    THE DICE-F1 CONNECTION:
    For binary segmentation with probabilistic (soft) predictions:
    - Dice and F1 are mathematically equivalent!
    - F1 = 2 * (precision * recall) / (precision + recall)
    - Dice = 2 * intersection / (pred_sum + truth_sum)
    - Both balance between finding objects (recall) and not over-predicting (precision)

    WHY USE F1 VS DICE:
    - Dice is more intuitive for pixel overlap
    - F1 is standard in ML literature
    - For segmentation, they measure the same thing
    """
    # This is mathematically identical to dice_coef for soft predictions
    return dice_coef(y_true, y_pred, eps=eps)


def f_beta(y_true: torch.Tensor, y_pred: torch.Tensor, beta: float = 2.0, eps: float = _EPS) -> torch.Tensor:
    """
    F-Beta Score: Weighted harmonic mean of Precision and Recall.

    WHAT BETA DOES:
    F_beta = (1 + beta^2) * (precision * recall) / (beta^2 * precision + recall)

    BETA INTERPRETATION:
    - beta = 1.0 (F1): Equal weight to precision and recall
    - beta = 2.0 (F2): Recall twice as important as precision
      → Prefers catching all bubbles, tolerates some false alarms
    - beta = 0.5 (F0.5): Precision twice as important as recall
      → Prefers accuracy, accepts missing some bubbles

    FOR BUBBLE DETECTION:
    beta=2.0 is common because missing a bubble (FN) is costlier than a false alarm (FP).
    It emphasizes sensitivity: "Don't miss the defects!"
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Threshold predictions at 0.5
    yb = (yp >= 0.5).float()

    # Count TP, FP, FN across all pixels
    tp = torch.sum(yb * yt, dim=(1, 2, 3))
    fp = torch.sum(yb * (1 - yt), dim=(1, 2, 3))
    fn = torch.sum((1 - yb) * yt, dim=(1, 2, 3))

    # Precision: "of what we predicted as bubbles, how many were correct?"
    prec = (tp + eps) / (tp + fp + eps)

    # Recall: "of actual bubbles, how many did we find?" (same as sensitivity)
    rec = (tp + eps) / (tp + fn + eps)

    # F_beta formula with beta^2 weighting
    b2 = beta * beta
    fbeta = (1 + b2) * (prec * rec) / (b2 * prec + rec + eps)

    return fbeta.mean()  # Average across batch


# ================ Tversky & helpers ================
# Tversky is a generalization of Dice, useful for imbalanced segmentation

def tversky(
    y_true: torch.Tensor,
    y_pred: torch.Tensor,
    alpha: float = 0.5,
    beta: float = 0.5,
    eps: float = _EPS,
) -> torch.Tensor:
    """
    Tversky Index: A parametric generalization of Dice for imbalanced data.

    FORMULA: Tversky = TP / (TP + alpha*FP + beta*FN)
    - TP: True Positives (correctly detected bubbles)
    - FP: False Positives (background wrongly called bubble)
    - FN: False Negatives (bubbles missed)

    WHY TVERSKY FOR BUBBLES:
    Bubbles are rare objects. A model that predicts "no bubbles" has high accuracy/Dice
    but zero sensitivity. Tversky lets you penalize FN and FP asymmetrically.

    WHAT ALPHA CONTROLS (FP weight):
    - alpha = 0.0: Ignore false positives entirely (only care about finding bubbles)
    - alpha = 1.0: Weight FP same as FN (like Dice)
    - alpha = 0.5: Default; FP has half the penalty of FN

    WHAT BETA CONTROLS (FN weight):
    - beta = 0.0: Ignore false negatives (don't care if we miss bubbles)
    - beta = 1.0: Weight FN same as FP
    - beta = 0.5: Default; FN is 2x more costly than FP (we'd rather over-predict)

    INTERPRETATION:
    Tversky(alpha=0.5, beta=0.5) is between Dice and a sensitivity-focused metric.
    It says: "Finding bubbles matters more than avoiding false alarms, but false alarms still cost."
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    # Rename for clarity (p = prediction, g = ground truth, 1 = foreground, 0 = background)
    p1 = yp  # Predicted foreground (bubble probability)
    g1 = yt  # Ground truth foreground (bubble mask)
    p0 = 1.0 - p1  # Predicted background
    g0 = 1.0 - g1  # Ground truth background

    # Count TP, FP, FN as weighted sums (soft metrics because predictions are probabilistic)
    tp = torch.sum(p1 * g1, dim=(1, 2, 3))  # Predicted and true foreground overlap
    fp = torch.sum(p1 * g0, dim=(1, 2, 3))  # Predicted foreground but true background
    fn = torch.sum(p0 * g1, dim=(1, 2, 3))  # Predicted background but true foreground

    # Tversky with parametric penalty weights
    return ((tp + eps) / (tp + alpha * fp + beta * fn + eps)).mean()


def _tversky_loss(alpha: float, beta: float):
    """
    Factory function to create a Tversky loss with specific alpha/beta.

    Returns a loss function (to minimize) from Tversky (to maximize).
    Used with get_loss() to configure training loss functions.

    Example:
      loss_fn = _tversky_loss(alpha=0.3, beta=0.7)
      loss = loss_fn(y_true, y_pred)  # Returns scalar to minimize
    """
    def _fn(y_true: torch.Tensor, y_pred: torch.Tensor) -> torch.Tensor:
        # Loss = 1 - Tversky (we want to maximize Tversky, minimize loss)
        return 1.0 - tversky(y_true, y_pred, alpha=alpha, beta=beta)
    return _fn


# ================ Heavy metrics (distance in PIXELS, EDT-based) ================
# These measure boundary quality by looking at distances between predicted and true surfaces
# Much more computationally expensive than overlap metrics, but critical for boundary accuracy

def _require_scipy() -> None:
    """Guard clause: raise error if SciPy not installed (needed for EDT-based distances)."""
    if not _HAS_SCIPY:
        raise ImportError(
            "SciPy is required for EDT-based surface distances (HD95 / ASSD). "
            "Please install scipy (e.g. `pip install scipy`)."
        )


def _surface_np(mask_bool: "np.ndarray") -> "np.ndarray":
    """
    Extract the 1-pixel boundary (surface) of a binary mask using erosion.

    WHY THIS MATTERS FOR BUBBLES:
    The boundary is the edge between bubble and background. For boundary-based metrics
    (Hausdorff, NSD), we care only about this thin line, not the entire bubble interior.

    ALGORITHM: surface = original_mask XOR erode(original_mask)
    - Erode: shrink the mask by 1 pixel in all directions (8-connected)
    - XOR: pixels that remain after erosion are interior; XOR gives us the edge

    INTERPRETATION:
    If a bubble is 10x10, its boundary is just the perimeter (~40 pixels).
    This makes boundary metrics more sensitive to shape distortions than overlap metrics.
    """
    if mask_bool.ndim != 2:
        raise ValueError(f"mask must be 2D, got {mask_bool.ndim}D")
    if mask_bool.sum() == 0:
        # Empty mask has no surface
        return np.zeros_like(mask_bool, dtype=bool)

    # Erode using 8-connected neighborhood (3x3 all-ones kernel)
    # border_value=0: pixels outside the array are treated as background
    er = binary_erosion(mask_bool, structure=np.ones((3, 3), dtype=bool), border_value=0)

    # XOR: pixels in original but not in eroded = boundary pixels
    return np.logical_xor(mask_bool, er)


def _assd_and_hd95_pixels_2d(
    gt_bool: "np.ndarray",
    pr_bool: "np.ndarray",
) -> Tuple[float, float]:
    """
    Compute Average Surface Distance (ASSD) and Hausdorff Distance 95th percentile (HD95)
    in PIXELS for a single 2D mask pair, using Euclidean Distance Transform (EDT).

    ASSD (Average Surface Distance):
    - Average distance from predicted surface to nearest ground-truth surface pixel
    - Plus average distance from GT surface to nearest predicted surface pixel
    - Lower is better; 0 = perfect boundary alignment

    HD95 (Hausdorff Distance 95th percentile):
    - Max distance at the 95th percentile (not the absolute max, which can be an outlier)
    - Measures the worst (but not the absolute worst) boundary deviation
    - Lower is better; 0 = perfect boundary alignment
    - The 95th percentile makes it more robust to a few outlier pixels than using the max

    WHY USE EDT:
    EDT computes distance from every pixel to the nearest background pixel.
    By computing EDT on the complement (~s), we get distance to the nearest surface pixel.

    ALGORITHM:
    1. Extract surfaces (boundaries) of both masks using erosion
    2. Compute EDT on complement of each surface
    3. Query the distance map at surface pixel locations
    4. Compute percentiles and averages
    """
    # Extract 1-pixel boundaries from both masks
    s_gt = _surface_np(gt_bool)
    s_pr = _surface_np(pr_bool)

    # Diagonal of image in pixels (used as penalty for empty masks)
    H, W = gt_bool.shape
    diag = float(np.sqrt(H * H + W * W))

    # Edge case 1: both surfaces empty => perfect match (distance 0)
    if s_gt.sum() == 0 and s_pr.sum() == 0:
        return 0.0, 0.0

    # Edge case 2: exactly one surface empty => huge penalty (image diagonal)
    if s_gt.sum() == 0 or s_pr.sum() == 0:
        return diag, diag

    # Compute EDT on the COMPLEMENT of surfaces
    # This gives us: for each pixel, distance to nearest surface pixel
    dt_gt = distance_transform_edt(~s_gt)  # Distance to nearest GT surface
    dt_pr = distance_transform_edt(~s_pr)  # Distance to nearest predicted surface

    # Sample distance maps at surface pixel locations
    d_pr_to_gt = dt_gt[s_pr]  # For each predicted surface pixel, distance to nearest GT surface
    d_gt_to_pr = dt_pr[s_gt]  # For each GT surface pixel, distance to nearest predicted surface

    # Safety: if somehow no surface pixels exist, return penalty
    if d_pr_to_gt.size == 0 or d_gt_to_pr.size == 0:
        return diag, diag

    # ASSD: average of bidirectional surface distances
    assd = 0.5 * (float(d_pr_to_gt.mean()) + float(d_gt_to_pr.mean()))

    # HD95: 95th percentile of bidirectional distances
    # (more robust to outliers than maximum distance)
    hd95 = max(
        float(np.percentile(d_pr_to_gt, 95)),  # 95th percentile of pred->GT distances
        float(np.percentile(d_gt_to_pr, 95)),  # 95th percentile of GT->pred distances
    )
    return assd, hd95


def normalized_surface_distance(
    y_true: torch.Tensor,
    y_pred: torch.Tensor,
    tau_px: float = 1.0,
    eps: float = _EPS,
) -> torch.Tensor:
    """
    Normalized Surface Distance (NSD) / Surface Dice with tolerance tau.

    Returns in [0,1], higher is better.
    NSD = ( #pred-surface points within tau of GT surface  +  #GT-surface points within tau of pred surface )
          / ( #pred-surface points + #GT-surface points )

    Edge cases (choose and document):
      - both empty => 1.0 (perfect match of "no object")
      - exactly one empty => 0.0
    """
    _require_scipy()
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    yp_bin = (yp >= 0.5)
    yt_bin = (yt >= 0.5)

    vals = []
    B = int(yt.shape[0])
    for b in range(B):
        gt = yt_bin[b, 0].detach().cpu().numpy().astype(bool)
        pr = yp_bin[b, 0].detach().cpu().numpy().astype(bool)

        s_gt = _surface_np(gt)
        s_pr = _surface_np(pr)

        n_gt = int(s_gt.sum())
        n_pr = int(s_pr.sum())

        if n_gt == 0 and n_pr == 0:
            vals.append(torch.tensor(1.0, device=yt.device, dtype=yt.dtype))
            continue
        if n_gt == 0 or n_pr == 0:
            vals.append(torch.tensor(0.0, device=yt.device, dtype=yt.dtype))
            continue

        # distance to nearest surface pixel (EDT on complement of surface)
        dt_gt = distance_transform_edt(~s_gt)
        dt_pr = distance_transform_edt(~s_pr)

        # count surface points within tolerance
        tp_pr = float((dt_gt[s_pr] <= tau_px).sum())
        tp_gt = float((dt_pr[s_gt] <= tau_px).sum())

        nsd = (tp_pr + tp_gt) / (n_pr + n_gt + eps)
        vals.append(torch.tensor(nsd, device=yt.device, dtype=yt.dtype))

    return torch.stack(vals).mean()



def Hausdorff_distance(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    95th percentile Hausdorff distance (HD95) in PIXELS.
    Lower is better.

    Definition:
      HD95 = max( p95(pred_surface -> true_surface), p95(true_surface -> pred_surface) )

    Uses exact Euclidean Distance Transform (EDT) on 1-pixel surfaces.

    Edge cases:
      - both masks empty => 0
      - exactly one mask empty => image diagonal in pixels (penalty)
    """
    _require_scipy()
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    yp_bin = (yp >= 0.5)
    yt_bin = (yt >= 0.5)

    vals = []
    B = int(yt.shape[0])
    for b in range(B):
        gt = yt_bin[b, 0].detach().cpu().numpy().astype(bool)
        pr = yp_bin[b, 0].detach().cpu().numpy().astype(bool)
        _, hd95 = _assd_and_hd95_pixels_2d(gt, pr)
        vals.append(torch.tensor(hd95, device=yt.device, dtype=yt.dtype))
    return torch.stack(vals).mean()


def boundary_intersection_over_union(y_true: torch.Tensor, y_pred: torch.Tensor, eps: float = _EPS) -> torch.Tensor:
    """
    Boundary IoU: IoU computed specifically on boundary regions.
    Higher is better.

    Note: this is very sensitive to 1px shifts if boundary thickness is 1 pixel.
    """
    yt, yp = _ensure_nchw_1(y_true, y_pred)

    yp_bin = (yp >= 0.5).float()
    yt_bin = (yt >= 0.5).float()

    # Keep your existing erosion-based boundary extraction (torch, GPU-friendly).
    boundary_true = _extract_boundaries(yt_bin, dilation_iters=1)
    boundary_pred = _extract_boundaries(yp_bin, dilation_iters=1)

    intersection = torch.sum(boundary_true * boundary_pred, dim=(1, 2, 3))
    union = torch.sum(boundary_true + boundary_pred, dim=(1, 2, 3)) - intersection

    boundary_iou = torch.where(
        union > eps,
        (intersection + eps) / (union + eps),
        torch.ones_like(intersection),
    )
    return boundary_iou.mean()


def _extract_boundaries(mask: torch.Tensor, dilation_iters: int = 1) -> torch.Tensor:
    """
    Extract boundaries from a binary mask using erosion (torch).
    Returns boundary pixels (edge between foreground and background).
    """
    binary_mask = (mask >= 0.5).float()
    kernel = torch.ones(1, 1, 3, 3, device=mask.device, dtype=mask.dtype)

    eroded = binary_mask
    for _ in range(max(1, int(dilation_iters))):
        eroded = F.conv2d(eroded, kernel, padding=1)
        eroded = (eroded >= 9.0).float()

    boundary = torch.clamp(binary_mask - eroded, 0.0, 1.0)
    return boundary


# ----------------- Factory -----------------
def get_loss(name: str, alphabeta=(0.5, 0.5)):
    n = (name or "").lower()
    if n.startswith("tversky"):
        a, b = alphabeta if isinstance(alphabeta, (tuple, list)) and len(alphabeta) == 2 else (0.5, 0.5)
        return _tversky_loss(float(a), float(b))
    if n in {"dice", "dice_loss"}:
        return dice_loss
    if n in {"bce"}:
        return lambda yt, yp: F.binary_cross_entropy(
            torch.clamp(yp.float(), _EPS, 1.0 - _EPS),
            torch.clamp(yt.float(), 0.0, 1.0),
        )
    # default
    a, b = alphabeta if isinstance(alphabeta, (tuple, list)) and len(alphabeta) == 2 else (0.5, 0.5)
    return _tversky_loss(float(a), float(b))
